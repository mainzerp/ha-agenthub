# agent-assist infrastructure environment variables
# Only infrastructure settings use env vars. All other configuration
# (HA connection, LLM keys, agent settings, etc.) is managed through
# the setup wizard and admin UI.

# Container bind address (default: 0.0.0.0)
# CONTAINER_HOST=0.0.0.0

# Container bind port (default: 8080)
# CONTAINER_PORT=8080

# Logging verbosity: DEBUG, INFO, WARNING, ERROR (default: INFO)
# LOG_LEVEL=INFO

# ChromaDB storage path (default: /data/chromadb)
# CHROMADB_PERSIST_DIR=/data/chromadb

# SQLite database file path (default: /data/agent_assist.db)
# SQLITE_DB_PATH=/data/agent_assist.db

# Require secure cookies (set to true in production with HTTPS)
# COOKIE_SECURE=false

# Path to Fernet key file for encryption at rest
# FERNET_KEY_PATH=/data/fernet.key

# Run HuggingFace in offline mode (no model download)
# HF_HUB_OFFLINE=0

# Docker image tag override (default: latest)
# HA_AGENTHUB_TAG=latest

# CORS origins (comma-separated, default: empty)
# CORS_ORIGINS=

# Trusted proxy IPs (comma-separated, default: empty)
# TRUSTED_PROXIES=
